# Copy to .env.local or export these variables before launching.
# scripts/run_stack_bowls_collection.sh, scripts/open_collection_ui.sh, and
# scripts/validate_environment.py auto-load .env.local.
OPENPI_ROOT=/path/to/openpi
CHECKPOINT_DIR=/path/to/pi05_checkpoint_dir
# Optional. If empty, the runtime resolves norm_stats.json from checkpoint metadata/assets.
NORM_STATS_PATH=

COLLECTION_OUTPUT_ROOT=/path/to/output/piper_correction_YYYYMMDD_HHMMSS
COLLECTION_REPO_ID=local/piper_correction_collection
NUM_EPISODES=100
GUI=true
ENABLE_ARM=true
DEVICE=cuda
PIPER_CAN_NAME=can1
ACTION_SCALE=1.0
MAX_ABS_DELTA=0.04

# Optional overrides.
ROBOT_RUNTIME_ROOT=./vendor/lerobot_piper
POLICY_RUNTIME_SCRIPT=./runtime/piper_openpi_runtime.py
BROWSER_BIN=
UI_LOG_DIR=/tmp

# Update these serials for your rig.
HEAD_CAMERA_SERIAL=254622073267
LEFT_WRIST_CAMERA_SERIAL=244222071617
RIGHT_WRIST_CAMERA_SERIAL=317622070857
FRONT_VIEW_CAMERA_SERIAL=254622079402
